---
import fs from "node:fs";
import path from "node:path";

interface Props {
  eyebrow?: string;
  title: string;
  lede?: string;
  primaryCta?: { href: string; label: string };
  secondaryCta?: { href: string; label: string };
  /** Optional image rendered to the right of the copy on desktop.
   *  At build time, if the file does not exist in `public/`, a styled
   *  phone-shaped placeholder renders instead so the layout never breaks. */
  image?: { src: string; alt: string };
}

const { eyebrow, title, lede, primaryCta, secondaryCta, image } = Astro.props;

// Build-time check: does the image actually exist?
let imageReady = false;
if (image) {
  const fsPath = path.join(process.cwd(), "public", image.src.replace(/^\//, ""));
  imageReady = fs.existsSync(fsPath);
}

const showRightCol = !!image; // reserve the column whether or not the file is there
---

<section class="relative overflow-hidden">
  {/* Soft lavender wash — brand accent applied at low opacity */}
  <div
    class="absolute inset-0 -z-10"
    style="background: radial-gradient(70% 55% at 25% 0%, #E8E7FA 0%, rgba(232,231,250,0) 65%), radial-gradient(55% 45% at 100% 15%, #F4F3FB 0%, rgba(244,243,251,0) 70%);"
    aria-hidden="true"
  ></div>

  <div class="container-page pt-24 pb-20 md:pt-32 md:pb-28">
    <div class={showRightCol ? "grid lg:grid-cols-12 gap-12 lg:gap-16 items-center" : ""}>
      <div class={showRightCol ? "lg:col-span-7" : ""}>
        {eyebrow && <p class="eyebrow mb-6">{eyebrow}</p>}
        <h1 class={`tracking-tight-3 ${showRightCol ? "" : "max-w-4xl"}`}>{title}</h1>
        {lede && <p class="lede mt-6">{lede}</p>}

        {(primaryCta || secondaryCta) && (
          <div class="mt-10 flex flex-wrap items-center gap-3">
            {primaryCta && (
              <a href={primaryCta.href} class="btn-primary">{primaryCta.label}</a>
            )}
            {secondaryCta && (
              <a href={secondaryCta.href} class="btn-secondary">{secondaryCta.label}</a>
            )}
          </div>
        )}
      </div>

      {showRightCol && (
        <div class="lg:col-span-5 flex justify-center lg:justify-end">
          <div class="relative w-full max-w-[320px] lg:max-w-[380px]">
            {/* Soft elevation under the device */}
            <div
              class="absolute -inset-6 -z-10 rounded-[40px] opacity-60 blur-2xl"
              style="background: radial-gradient(60% 60% at 50% 50%, #C9C7F4 0%, rgba(201,199,244,0) 70%);"
              aria-hidden="true"
            ></div>

            {imageReady ? (
              <img
                src={image!.src}
                alt={image!.alt}
                class="w-full h-auto rounded-[28px] shadow-[0_20px_60px_-20px_rgba(15,15,30,0.25)]"
                loading="eager"
                decoding="async"
              />
            ) : (
              /* Phone-shaped placeholder — auto-replaced when the real image lands. */
              <div
                class="aspect-[2/3] w-full rounded-[28px] border border-brand-line bg-gradient-to-b from-brand-subtle to-white shadow-[0_20px_60px_-20px_rgba(15,15,30,0.18)] flex items-center justify-center"
                role="img"
                aria-label={image!.alt}
              >
                <div class="flex flex-col items-center gap-3 px-6 text-center">
                  <img
                    src="/logos/mark-square.png"
                    alt=""
                    class="h-12 w-12 rounded-xl opacity-90"
                  />
                  <p class="text-xs uppercase tracking-[0.18em] text-brand-muted">
                    Product imagery
                  </p>
                  <p class="text-xs text-brand-muted/80 max-w-[200px]">
                    Phone mockup lands here once dropped in /public/images/.
                  </p>
                </div>
              </div>
            )}
          </div>
        </div>
      )}
    </div>
  </div>
</section>
