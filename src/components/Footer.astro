---
const year = new Date().getFullYear();
const cols = [
  {
    heading: "Company",
    links: [
      { href: "/about", label: "About" },
      { href: "/careers", label: "Careers" },
      { href: "/press", label: "Press" },
    ],
  },
  {
    heading: "Solutions",
    links: [
      { href: "/hearthai", label: "HearthAI" },
    ],
  },
  {
    heading: "Contact",
    links: [
      { href: "mailto:", label: "General inquiries" },
      { href: "mailto:", label: "Press" },
      { href: "mailto:", label: "Partnerships" },
    ],
  },
];
---

<footer class="hairline mt-24">
  <div class="container-page py-14">
    <div class="grid gap-10 md:grid-cols-4">
      <div>
        <img
          src="/logos/logo-primary.png"
          alt="Pereste"
          width="180"
          height="84"
          class="h-16 w-auto"
          loading="lazy"
          decoding="async"
        />
        <p class="mt-4 text-sm text-brand-muted max-w-xs leading-relaxed">
          Healthcare AI, deployed in partnership with institutions.
        </p>
      </div>

      {cols.map((col) => (
        <div>
          <h4 class="text-xs uppercase tracking-[0.18em] text-brand-muted font-medium">
            {col.heading}
          </h4>
          <ul class="mt-4 space-y-2">
            {col.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-brand-ink hover:text-brand-ink/60"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="hairline mt-12 pt-6 flex flex-col md:flex-row items-start md:items-center justify-between gap-3">
      <p class="text-xs text-brand-muted">
        © {year} Pereste LLC. Based in Louisiana, USA.
      </p>
      <p class="text-xs text-brand-muted">
        Pereste is a healthcare AI company. Information on this site is not medical advice.
      </p>
    </div>
  </div>
</footer>
